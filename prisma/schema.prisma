generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recording {
  id         String   @id @default(cuid())
  title      String   @default("")
  createdAt  DateTime @default(now())
  duration   Int      @default(0)
  fileSize   Int      @default(0)
  mimeType   String   @default("")
  audioPath  String   @default("")
  status     String   @default("uploading")

  chunks     ChunkBlob[]
  finalizeJob FinalizeJob?
  transcript Transcript?
  summary    Summary?
}

// Raw audio chunks stored during recording — transcribed in bulk at finalize time.
// Storing audio here (instead of transcribing inline) means the upload phase
// can never fail due to AI API errors, rate limits, or timeouts.
model ChunkBlob {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  audioData   Bytes
  offset      Float     @default(0)
  mimeType    String    @default("audio/webm")
  createdAt   DateTime  @default(now())

  @@index([recordingId, offset])
}

model FinalizeJob {
  id          String          @id @default(cuid())
  recordingId String          @unique
  recording   Recording       @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  status      String          @default("pending")
  attempts    Int             @default(0)
  lockToken   String?
  lockUntil   DateTime?
  lastError   String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  chunks      ChunkTranscript[]

  @@index([status, updatedAt])
}

model ChunkTranscript {
  id          String      @id @default(cuid())
  jobId        String
  job          FinalizeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  recordingId  String
  chunkId      String
  offset       Float       @default(0)
  status       String      @default("pending")
  attempts     Int         @default(0)
  lastError    String      @default("")
  transcript   String      @default("")
  segments     String      @default("[]")
  processedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([jobId, chunkId])
  @@index([recordingId, status, offset])
}

model Transcript {
  id          String    @id @default(cuid())
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  fullText    String
  segments    String
  createdAt   DateTime  @default(now())
}

model Summary {
  id          String    @id @default(cuid())
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  overview    String
  keyPoints   String
  actionItems String
  decisions   String
  topics      String    @default("[]")
  createdAt   DateTime  @default(now())
}
