generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recording {
  id         String   @id @default(cuid())
  title      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  duration   Int      @default(0)
  fileSize   Int      @default(0)
  mimeType   String   @default("")
  audioPath  String   @default("")
  status     String   @default("uploading")
  lockToken  String?
  lockUntil  DateTime?

  chunks     ChunkBlob[]
  transcript Transcript?
  summary    Summary?
}

// Raw audio chunks stored during recording — transcribed in bulk at finalize time.
// Storing audio here (instead of transcribing inline) means the upload phase
// can never fail due to AI API errors, rate limits, or timeouts.
model ChunkBlob {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  audioData   Bytes
  offset      Float     @default(0)
  mimeType    String    @default("audio/webm")
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String    @default("")
  transcript  String    @default("")
  segments    String    @default("[]")
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([recordingId, offset])
  @@index([recordingId, status])
}

model Transcript {
  id          String    @id @default(cuid())
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  fullText    String
  segments    String
  createdAt   DateTime  @default(now())
}

model Summary {
  id          String    @id @default(cuid())
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  overview    String
  keyPoints   String
  actionItems String
  decisions   String
  topics      String    @default("[]")
  createdAt   DateTime  @default(now())
}
