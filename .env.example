# Copy this file to .env.local and fill in your values

# OpenAI — used for Whisper audio transcription
OPENAI_API_KEY=sk-...

# Anthropic — used for Claude AI summarisation
ANTHROPIC_API_KEY=sk-ant-...

# Groq — FREE alternative to OpenAI for Whisper transcription (console.groq.com)
GROQ_API_KEY=gsk_...

# Database — Supabase PostgreSQL connection string
# Supabase project → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Vercel Cron auth secret (required in production for /api/jobs/finalize)
CRON_SECRET=choose_a_long_random_secret

# Airtable backup (optional — recordings are backed up here after processing)
# Create a personal access token at airtable.com/create/tokens
# Base needs a table called "Recordings" — see lib/airtable-backup.ts for the fields
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
